# Firebase Admin SDK - Service Account Credentials
# Get these from: Google Cloud Console > IAM & Admin > Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# IMPORTANT: For the private key, escape newlines as \n in Cloud Run env var
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Cloud Storage
GCS_BUCKET=wolfpackdna-images

# Server port (Cloud Run sets this automatically)
PORT=8080

# Optional: Email configuration (if implemented)
# FROM_EMAIL=noreply@wolfpackdna.com
# INTERNAL_EMAIL=admin@wolfpackdna.com